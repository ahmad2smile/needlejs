{
  "name": "needlejs",
  "version": "0.1.0",
  "description": "Needle tool-calling model — runs locally via ONNX with bundled weights.",
  "type": "module",
  "main": "dist/needle.umd.cjs",
  "module": "dist/needle.esm.js",
  "exports": {
    ".": {
      "import": "./dist/needle.esm.js",
      "require": "./dist/needle.umd.cjs"
    }
  },
  "files": [
    "src",
    "dist",
    "models/needle_encoder_fp16.onnx",
    "models/needle_decoder_fp16.onnx",
    "models/tokenizer/needle.model",
    "models/tokenizer/needle.vocab",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "onnxruntime-web": "^1.20.1",
    "sentencepiece-js": "^1.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.0.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  }
}
