{
  "name": "needlejs",
  "version": "0.1.0",
  "description": "Needle tool-calling model running in-browser via ONNX.js",
  "type": "module",
  "main": "dist/needle.umd.cjs",
  "module": "dist/needle.esm.js",
  "exports": {
    ".": {
      "import": "./dist/needle.esm.js",
      "require": "./dist/needle.umd.cjs"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:extension": "rollup -c rollup.extension.config.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "onnxruntime-web": "^1.20.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-copy": "^3.5.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
